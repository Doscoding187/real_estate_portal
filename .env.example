# ========================================
# Real Estate Portal - Environment Variables
# ========================================

# ---------------- Runtime / Database ----------------
# Local development should use a non-production database.
# Runtime database guard expectations:
# - NODE_ENV=development: any non-production database name is allowed.
# - NODE_ENV=test: database name must be listify_test.
# - NODE_ENV=staging: database name must be listify_staging.
# - NODE_ENV=production: database name must be listify_property_sa.
# The app refuses to use listify_property_sa outside production.
NODE_ENV=development
DATABASE_URL=mysql://real_estate_app:your_password@localhost:3306/listify_local

# ---------------- Authentication ----------------
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
OAUTH_SERVER_URL=https://your-oauth-server.com
OWNER_OPEN_ID=your-owner-open-id

# ---------------- Application ----------------
VITE_APP_ID=your-app-id
VITE_APP_TITLE=Real Estate Portal
VITE_APP_LOGO=/logo.png
VITE_API_URL=http://localhost:5000
# Base public app origin only. Do not include a path, query string, or hash fragment.
APP_URL=http://localhost:3009
VITE_APP_URL=http://localhost:3009
# Optional legacy fallback consumed by some server-side codepaths; same base-origin rule applies.
# NEXT_PUBLIC_APP_URL=http://localhost:3009

# ---------------- Manus Storage (Fallback) ----------------
BUILT_IN_FORGE_API_URL=https://your-forge-api.com
BUILT_IN_FORGE_API_KEY=your-forge-api-key

# ---------------- AWS S3 + CloudFront ----------------
# Required for production uploads. Local development can omit these unless testing uploads.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-secret-access-key
S3_BUCKET_NAME=your-property-images-bucket
CLOUDFRONT_URL=https://d111111abcdef8.cloudfront.net

# Image upload settings
MAX_IMAGE_SIZE_MB=10

# ---------------- Stripe (Subscription & Payments) ----------------
# Required only when testing billing/subscription flows or production payments.
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------- Google Maps ----------------
# Required for live map/place integrations. Unit tests should not require real keys.
GOOGLE_MAPS_API_KEY=replace-with-google-maps-key
GOOGLE_PLACES_API_KEY=replace-with-google-places-key
GOOGLE_GEOCODING_API_KEY=replace-with-google-geocoding-key
GOOGLE_STREET_VIEW_API_KEY=replace-with-google-street-view-key

# ---------------- Redis (Caching) ----------------
# Optional locally; the backend falls back to in-memory cache when Redis is not configured.
# Production should use the Railway Redis internal URL or equivalent managed Redis URL.
REDIS_URL=redis://localhost:6379

# ---------------- Analytics (Optional) ----------------
VITE_ANALYTICS_ENDPOINT=http://localhost:3000/analytics
VITE_ANALYTICS_WEBSITE_ID=local-test-site

# ========================================
# SETUP INSTRUCTIONS
# ========================================

# 1. Copy this file to .env.local for development or .env.test for tests.
#    cp .env.example .env.local

# 2. Update DATABASE_URL with the correct non-production MySQL/TiDB credentials.

# 3. Generate a secure JWT_SECRET
#    Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# 4. For AWS S3 + CloudFront (Production Image Storage):
#    - Follow FRONTEND_ARCHITECTURE.md > AWS Setup section
#    - Or use the Vercel + AWS guide for complete setup

# 5. For Stripe (Subscription features):
#    - Create account at https://stripe.com
#    - Get keys from Dashboard > Developers > API keys

# 6. For Google Maps (Location features):
#    - Create project at https://console.cloud.google.com
#    - Enable: Maps JavaScript API, Places API, Geocoding API, Street View API
#    - Create API key from Credentials section
