# Listify environment reference
#
# Safe to commit. This file is an audit-backed catalog of the env vars used by
# the app, tests, migrations, auth, uploads, email, payments, and integrations.
# Do not put production secrets here.
#
# Copy one of these instead of copying this full reference:
# - .env.local.example -> .env.local for local development
# - .env.test.example  -> .env.test for database-backed tests

# -----------------------------------------------------------------------------
# Core runtime - mandatory for real local app runs
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_ENV=development
PORT=5000
SKIP_FRONTEND=true
TRUST_PROXY=false
SKIP_DB_INIT=0
LOCAL_SEED_ALLOWED=false
LOCAL_DEMO_AGENCY_PASSWORD=replace-with-local-demo-password

# Mandatory for any DB-backed server, migration, or integration test run.
# Local dev may use any non-production DB except listify_property_sa.
# Test runtime must use database name listify_test.
DATABASE_URL=mysql://listify_app:listify_app_password@127.0.0.1:3307/listify_local

# Mandatory for auth/session/token flows. Generate a local value with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-local-random-32-byte-hex

# Mandatory origins for redirects, invite links, browser calls, and CORS.
APP_URL=http://localhost:3009
FRONTEND_URL=http://localhost:3009
BASE_URL=http://localhost:3009
NEXT_PUBLIC_APP_URL=http://localhost:3009

# Mandatory for the Vite client dev server.
VITE_APP_ID=listify-local
VITE_APP_ENV=development
VITE_DEPLOY_ENV=local
VITE_APP_URL=http://localhost:3009
VITE_API_URL=http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000
VITE_ASSETS_BASE_URL=

# -----------------------------------------------------------------------------
# Auth/bootstrap - optional unless testing these flows
# -----------------------------------------------------------------------------
OWNER_OPEN_ID=local-owner-open-id
OAUTH_SERVER_URL=

# Keep these blank locally unless deliberately testing admin seeding in a
# disposable database.
PROD_SUPERADMIN_EMAIL=
PROD_SUPERADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Feature flags and local behavior
# -----------------------------------------------------------------------------
FEATURE_DISTRIBUTION_NETWORK=true
VITE_FEATURE_TEAM_INVITATIONS=true
VITE_FEATURE_AUTO_SEND_INVITES=false
VITE_MAX_TEAM_INVITATIONS_PER_AGENCY=25
VITE_ONBOARDING_DRAFT_EXPIRY_HOURS=72
VITE_USE_MOCK_EMAILS=true
AUTH_RATE_LIMIT_MAX=50

# -----------------------------------------------------------------------------
# Redis - optional locally
# -----------------------------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Email - optional locally, required only for real email sending
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=Listify Local <onboarding@resend.dev>
EMAIL_FROM=Listify Local <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# Storage, uploads, and video - optional unless testing real media flows
# -----------------------------------------------------------------------------
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_S3_BUCKET=
CLOUDFRONT_URL=
VITE_CLOUDFRONT_URL=
MAX_IMAGE_SIZE_MB=10
ENABLE_VIDEO_PIPELINE=false
MEDIACONVERT_ENDPOINT=
MEDIACONVERT_ROLE_ARN=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# -----------------------------------------------------------------------------
# Manual EFT billing - placeholders only, configure real values in secrets manager
# -----------------------------------------------------------------------------
BILLING_EFT_ACCOUNT_NAME=replace-with-production-account-name
BILLING_EFT_BANK_NAME=replace-with-production-bank-name
BILLING_EFT_BRANCH_CODE=replace-with-production-branch-code
BILLING_EFT_ACCOUNT_NUMBER=replace-with-production-account-number
BILLING_EFT_ACCOUNT_TYPE=replace-with-production-account-type
BILLING_SUPPORT_EMAIL=billing@example.invalid

# Local/dev can use local private storage. Production requires private S3 config.
BILLING_PROOF_STORAGE_ADAPTER=local
BILLING_PRIVATE_STORAGE_DIR=.private/billing-proofs
BILLING_PROOF_S3_BUCKET=
BILLING_PROOF_S3_REGION=
BILLING_PROOF_S3_PREFIX=billing-proofs
BILLING_PROOF_AWS_ACCESS_KEY_ID=
BILLING_PROOF_AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Payments - optional, use Stripe test-mode values only
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# -----------------------------------------------------------------------------
# Maps, places, geocoding, and street view - optional unless testing map flows
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_STREET_VIEW_API_KEY=
GOOGLE_PLACES_COUNTRY_RESTRICTION=ZA
AUTOCOMPLETE_DEBOUNCE_MS=300
AUTOCOMPLETE_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# AI, CMS, and content rules - optional
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
CONTENTFUL_SPACE_ID=
CONTENTFUL_API_KEY=
MEDIA_RULES_PATH=

# -----------------------------------------------------------------------------
# Saved search delivery - optional locally
# -----------------------------------------------------------------------------
SAVED_SEARCH_ACTION_TOKEN_SECRET=replace-with-local-random-token
SAVED_SEARCH_SCHEDULER_ENABLED=false
SAVED_SEARCH_SCHEDULER_INTERVAL_MS=300000

# -----------------------------------------------------------------------------
# Distribution affordability defaults - optional tuning
# -----------------------------------------------------------------------------
DISTRIBUTION_AFFORDABILITY_INTEREST_RATE_ANNUAL=11.75
DISTRIBUTION_AFFORDABILITY_TERM_MONTHS=240
DISTRIBUTION_AFFORDABILITY_MAX_REPAYMENT_RATIO=0.30
DISTRIBUTION_AFFORDABILITY_LOW_CONFIDENCE_INCOME=15000

# -----------------------------------------------------------------------------
# TiDB and legacy DB aliases - optional fallback for legacy scripts
# -----------------------------------------------------------------------------
TIDB_HOST=
TIDB_PORT=4000
TIDB_USER=
TIDB_PASSWORD=
TIDB_DATABASE=
DB_HOST=
DB_NAME=

# -----------------------------------------------------------------------------
# Production reset guards - keep disabled locally
# -----------------------------------------------------------------------------
PROD=false
PROD_RESET_ENABLED=false
PROD_RESET_CONFIRM=

# -----------------------------------------------------------------------------
# CI/deployment metadata - normally supplied by hosting providers
# -----------------------------------------------------------------------------
CI=false
DEV=true
MODE=development
API_URL=http://localhost:5000
VERCEL_ENV=
VERCEL_GIT_COMMIT_SHA=
GITHUB_SHA=
COMMIT_SHA=
RAILWAY_ENVIRONMENT=
RAILWAY_ENVIRONMENT_NAME=
RAILWAY_GIT_COMMIT_SHA=
RAILWAY_PUBLIC_DOMAIN=
BUILD_TIME=
