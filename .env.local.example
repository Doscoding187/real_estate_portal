# Listify local development env
#
# Copy to .env.local. Placeholder values are safe for local use only.
# Never point DATABASE_URL at production.

NODE_ENV=development
APP_ENV=development
PORT=5000
SKIP_FRONTEND=true
TRUST_PROXY=false
SKIP_DB_INIT=0
LOCAL_SEED_ALLOWED=false
LOCAL_DEMO_AGENCY_PASSWORD=replace-with-local-demo-password

# Recommended Docker MySQL local database:
# docker run --name listify-mysql-local -e MYSQL_ROOT_PASSWORD=listify_root_password -e MYSQL_DATABASE=listify_local -e MYSQL_USER=listify_app -e MYSQL_PASSWORD=listify_app_password -p 3307:3306 -d mysql:8.0
DATABASE_URL=mysql://listify_app:listify_app_password@127.0.0.1:3307/listify_local

JWT_SECRET=replace-with-local-random-32-byte-hex

APP_URL=http://localhost:3009
FRONTEND_URL=http://localhost:3009
BASE_URL=http://localhost:3009
NEXT_PUBLIC_APP_URL=http://localhost:3009

VITE_APP_ID=listify-local
VITE_APP_ENV=development
VITE_DEPLOY_ENV=local
VITE_APP_URL=http://localhost:3009
VITE_API_URL=http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000
VITE_ASSETS_BASE_URL=
API_URL=http://localhost:5000

FEATURE_DISTRIBUTION_NETWORK=true
VITE_FEATURE_TEAM_INVITATIONS=true
VITE_FEATURE_AUTO_SEND_INVITES=false
VITE_MAX_TEAM_INVITATIONS_PER_AGENCY=25
VITE_ONBOARDING_DRAFT_EXPIRY_HOURS=72
VITE_USE_MOCK_EMAILS=true
AUTH_RATE_LIMIT_MAX=50

# Optional local Redis. Leave blank if you are not testing cache-backed behavior.
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional email. Leave RESEND_API_KEY blank to avoid real email sending.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Listify Local <onboarding@resend.dev>
EMAIL_FROM=Listify Local <onboarding@resend.dev>

# Optional uploads/storage. Leave credentials blank unless using a sandbox bucket.
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_S3_BUCKET=
CLOUDFRONT_URL=
VITE_CLOUDFRONT_URL=
MAX_IMAGE_SIZE_MB=10
ENABLE_VIDEO_PIPELINE=false
MEDIACONVERT_ENDPOINT=
MEDIACONVERT_ROLE_ARN=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Manual EFT billing. These local values are placeholders and must not be paid.
BILLING_EFT_ACCOUNT_NAME=LOCAL TEST EFT ACCOUNT - NOT PAYABLE
BILLING_EFT_BANK_NAME=Local Test Bank
BILLING_EFT_BRANCH_CODE=000000
BILLING_EFT_ACCOUNT_NUMBER=0000000000
BILLING_EFT_ACCOUNT_TYPE=Local test account
BILLING_SUPPORT_EMAIL=billing-test@propertylistify.local

# Local proof storage is development-only private disk storage. Production must use S3.
BILLING_PROOF_STORAGE_ADAPTER=local
BILLING_PRIVATE_STORAGE_DIR=.private/billing-proofs
BILLING_PROOF_S3_BUCKET=
BILLING_PROOF_S3_REGION=
BILLING_PROOF_S3_PREFIX=billing-proofs
BILLING_PROOF_AWS_ACCESS_KEY_ID=
BILLING_PROOF_AWS_SECRET_ACCESS_KEY=

# Optional Stripe test-mode values only.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional maps/places keys.
GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_STREET_VIEW_API_KEY=
GOOGLE_PLACES_COUNTRY_RESTRICTION=ZA
AUTOCOMPLETE_DEBOUNCE_MS=300
AUTOCOMPLETE_CACHE_TTL_SECONDS=300

# Optional AI/CMS integrations.
OPENAI_API_KEY=
CONTENTFUL_SPACE_ID=
CONTENTFUL_API_KEY=
MEDIA_RULES_PATH=

# Optional saved-search scheduler.
SAVED_SEARCH_ACTION_TOKEN_SECRET=replace-with-local-random-token
SAVED_SEARCH_SCHEDULER_ENABLED=false
SAVED_SEARCH_SCHEDULER_INTERVAL_MS=300000

# Optional affordability tuning for distribution matching.
DISTRIBUTION_AFFORDABILITY_INTEREST_RATE_ANNUAL=11.75
DISTRIBUTION_AFFORDABILITY_TERM_MONTHS=240
DISTRIBUTION_AFFORDABILITY_MAX_REPAYMENT_RATIO=0.30
DISTRIBUTION_AFFORDABILITY_LOW_CONFIDENCE_INCOME=15000

# Optional auth/bootstrap placeholders.
OWNER_OPEN_ID=local-owner-open-id
OAUTH_SERVER_URL=

# Keep production reset/admin seeding disabled locally.
PROD=false
PROD_RESET_ENABLED=false
PROD_RESET_CONFIRM=
PROD_SUPERADMIN_EMAIL=
PROD_SUPERADMIN_PASSWORD=
