{
  "buildCommand": "pnpm build:frontend",
  "outputDirectory": "dist/public",
  "framework": null,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://api.propertylistifysa.co.za/api/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
