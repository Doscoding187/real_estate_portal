{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "downlevelIteration": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/*.example.ts",
    "**/*.example.tsx",
    "**/*.backup.ts",
    "**/*.backup.tsx",
    "**/*.demo.ts",
    "**/*.demo.tsx",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "server/scripts/**",
    "server/db_*.ts",
    "server/**/debug-*.ts",
    "client/**/stories/**",
    "server/services/locationPagesService.improved.ts",
    "**/server/services/locationPagesService.improved.ts"
  ]
}
