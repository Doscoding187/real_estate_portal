# Listify test environment
#
# Copy to .env.test for database-backed tests. This must use a disposable
# database named listify_test. Never point this at production.

NODE_ENV=test
APP_ENV=test
PORT=5001
SKIP_FRONTEND=true
TRUST_PROXY=false
SKIP_DB_INIT=0
LOCAL_SEED_ALLOWED=false
LOCAL_DEMO_AGENCY_PASSWORD=replace-with-test-demo-password

# Required for integration tests and test migrations.
# The database name must be listify_test because the runtime guard checks it.
DATABASE_URL=mysql://listify_test:listify_test_password@127.0.0.1:3307/listify_test

JWT_SECRET=replace-with-test-random-32-byte-hex

APP_URL=http://localhost:3009
FRONTEND_URL=http://localhost:3009
BASE_URL=http://localhost:3009
NEXT_PUBLIC_APP_URL=http://localhost:3009

VITE_APP_ID=listify-test
VITE_APP_ENV=test
VITE_DEPLOY_ENV=test
VITE_APP_URL=http://localhost:3009
VITE_API_URL=http://localhost:5001
VITE_API_BASE_URL=http://localhost:5001
VITE_ASSETS_BASE_URL=
API_URL=http://localhost:5001

FEATURE_DISTRIBUTION_NETWORK=true
VITE_USE_MOCK_EMAILS=true
VITE_FEATURE_TEAM_INVITATIONS=true
VITE_FEATURE_AUTO_SEND_INVITES=false
VITE_MAX_TEAM_INVITATIONS_PER_AGENCY=25
VITE_ONBOARDING_DRAFT_EXPIRY_HOURS=72
AUTH_RATE_LIMIT_MAX=50

# Keep real integrations disabled for tests unless a test explicitly stubs them.
REDIS_URL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Listify Test <onboarding@resend.dev>
EMAIL_FROM=Listify Test <onboarding@resend.dev>

AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
AWS_S3_BUCKET=
CLOUDFRONT_URL=
VITE_CLOUDFRONT_URL=
MAX_IMAGE_SIZE_MB=10
ENABLE_VIDEO_PIPELINE=false
MEDIACONVERT_ENDPOINT=
MEDIACONVERT_ROLE_ARN=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

BILLING_EFT_ACCOUNT_NAME=LOCAL TEST EFT ACCOUNT - NOT PAYABLE
BILLING_EFT_BANK_NAME=Local Test Bank
BILLING_EFT_BRANCH_CODE=000000
BILLING_EFT_ACCOUNT_NUMBER=0000000000
BILLING_EFT_ACCOUNT_TYPE=Local test account
BILLING_SUPPORT_EMAIL=billing-test@propertylistify.local
BILLING_PROOF_STORAGE_ADAPTER=local
BILLING_PRIVATE_STORAGE_DIR=/tmp/property-listify-billing-proofs
BILLING_PROOF_S3_BUCKET=
BILLING_PROOF_S3_REGION=
BILLING_PROOF_S3_PREFIX=billing-proofs
BILLING_PROOF_AWS_ACCESS_KEY_ID=
BILLING_PROOF_AWS_SECRET_ACCESS_KEY=

STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_STREET_VIEW_API_KEY=
GOOGLE_PLACES_COUNTRY_RESTRICTION=ZA
AUTOCOMPLETE_DEBOUNCE_MS=300
AUTOCOMPLETE_CACHE_TTL_SECONDS=300

OPENAI_API_KEY=
CONTENTFUL_SPACE_ID=
CONTENTFUL_API_KEY=
MEDIA_RULES_PATH=

SAVED_SEARCH_ACTION_TOKEN_SECRET=replace-with-test-random-token
SAVED_SEARCH_SCHEDULER_ENABLED=false
SAVED_SEARCH_SCHEDULER_INTERVAL_MS=300000

DISTRIBUTION_AFFORDABILITY_INTEREST_RATE_ANNUAL=11.75
DISTRIBUTION_AFFORDABILITY_TERM_MONTHS=240
DISTRIBUTION_AFFORDABILITY_MAX_REPAYMENT_RATIO=0.30
DISTRIBUTION_AFFORDABILITY_LOW_CONFIDENCE_INCOME=15000

OWNER_OPEN_ID=test-owner-open-id
OAUTH_SERVER_URL=

# Leave unset/disabled. Tests should not run production reset or prod seeding.
PROD=false
PROD_RESET_ENABLED=false
PROD_RESET_CONFIRM=
PROD_SUPERADMIN_EMAIL=
PROD_SUPERADMIN_PASSWORD=
